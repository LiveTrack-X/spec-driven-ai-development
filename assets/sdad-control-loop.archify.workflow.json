  "cards": [
    {
      "dot": "cyan",
      "title": "Context Layers",
      "items": [
        "Adapter -> state -> INDEX stays fixed",
        "Current source/tests precede routed docs",
        "One policy or playbook loads on demand"
      ]
    },
    {
      "dot": "rose",
      "title": "Risk Boundary",
      "items": [
        "Inspect, document, or test is Standard minimum",
        "Change, accept, or execute uses Full + Level 4",
        "Push, tag, and publish follow the owner release gate"
      ]
    },
    {
      "dot": "emerald",
      "title": "Operating Loop",
      "items": [
        "Pain becomes SPEC",
        "SPEC becomes a bounded packet",
        "Repeated pain becomes a rule, test, template, or gate"
      ]
